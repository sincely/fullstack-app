{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Vue Debugger",
      "url": "http://localhost:9527",
      "webRoot": "${workspaceFolder}/client"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Server Debugger",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--enable-source-maps"],
      "program": "${workspaceFolder}/server/src/app.js",
      "cwd": "${workspaceFolder}/server",
      "envFile": "${workspaceFolder}/server/.env.development",
      "env": {
        "NODE_ENV": "development"
      },
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/server/node_modules/**"],
      "resolveSourceMapLocations": ["${workspaceFolder}/server/**", "!**/node_modules/**"],
      "smartStep": true,
      "console": "integratedTerminal",
      "outputCapture": "std",
      "internalConsoleOptions": "neverOpen",
      "restart": true,
      "autoAttachChildProcesses": true,
      "attachSimplePort": 0
    }
  ]
}
