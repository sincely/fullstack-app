    "@vitejs/plugin-vue-jsx": "5.1.3",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-define-config": "2.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-vue": "9.24.1",
    "lint-staged": "15.2.2",
