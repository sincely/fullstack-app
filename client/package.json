    "@sa/hooks": "workspace:*",
    "@sa/materials": "workspace:*",
    "@sa/utils": "workspace:*",
    "@vueuse/core": "10.9.0",
    "ant-design-vue": "4.2.6",
    "clipboard": "2.0.11",
    "dayjs": "1.11.10",
    "echarts": "5.5.0",
    "lodash-es": "4.17.21",
    "nprogress": "0.2.0",
    "pinia": "2.2.2",
    "vue": "3.5.13",
    "vue-draggable-plus": "0.5.3",
    "vue-router": "4.3.0"
  },
  "devDependencies": {
    "@elegant-router/vue": "0.3.8",
