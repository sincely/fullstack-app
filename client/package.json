{
  "name": "client",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@8.15.6",
  "description": "A fresh and elegant admin template, based on Vue3,Vite3,AntDesign and UnoCSS.",
  "scripts": {
    "dev": "vite --mode test",
    "build:prod": "vite build --mode production",
    "build:test": "vite build --mode test",
