    "eslint:fix": "eslint \"src/**/*.{vue,js,jsx}\" --fix",
    "prettier:fix": "prettier --write \"src/**/*.{js,vue,scss,css,json,html}\"",
    "lint-staged": "lint-staged",
    "prepare": "husky install"
  },
  "dependencies": {
