VITE_BASE_URL=/

VITE_APP_TITLE=SoybeanAdmin

VITE_APP_DESC=SoybeanAdmin is a fresh and elegant admin template

# 图标名称前缀
VITE_ICON_PREFIX=icon

# 本地 svg 图标组件前缀，必须包含 VITE_ICON_PREFIX
# 格式：{VITE_ICON_PREFIX}-{本地图标名称}
VITE_ICON_LOCAL_PREFIX=icon-local

# 权限路由模式：static ｜ dynamic
VITE_AUTH_ROUTE_MODE=static

# 静态权限路由首页
VITE_ROUTE_HOME=home

# 默认菜单图标
VITE_MENU_ICON=mdi:menu

# 开发模式下是否启用 HTTP 代理
VITE_HTTP_PROXY=Y

# vue-router 模式：hash | history | memory
VITE_ROUTER_HISTORY_MODE=history

# 后端接口成功码，命中该状态码表示请求成功
VITE_SERVICE_SUCCESS_CODE=0000

# 后端接口登出状态码，命中后将登出并跳转到登录页
VITE_SERVICE_LOGOUT_CODES=8888,8889

# 后端接口弹窗登出状态码，命中后会弹窗提示并登出
VITE_SERVICE_MODAL_LOGOUT_CODES=7777,7778

# 后端接口 token 过期状态码，命中后会刷新 token 并重发请求
VITE_SERVICE_EXPIRED_TOKEN_CODES=9999,9998,3333

# 当路由模式为 static 时定义的超级角色
VITE_STATIC_SUPER_ROLE=R_SUPER

# 用于区分不同域名下的本地存储
VITE_STORAGE_PREFIX=SOY_

# 用于控制程序是否自动检测更新
VITE_AUTOMATICALLY_DETECT_UPDATE=Y
