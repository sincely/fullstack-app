# 后端服务基础地址（测试环境）
# VITE_SERVICE_BASE_URL=https://apifoxmock.com/m1/3109515-0-default
VITE_SERVICE_BASE_URL=http://localhost:8080
# 其他后端服务基础地址（测试环境）
VITE_OTHER_SERVICE_BASE_URL= `{
  "demo": "http://localhost:9528"
}`

# 后端接口成功码（对应 businessCode.success=200）
VITE_SERVICE_SUCCESS_CODE=200

# 后端接口登出状态码（包含账号被踢下线 1002）
VITE_SERVICE_LOGOUT_CODES=8888,8889,1002

# 后端接口弹窗登出状态码
VITE_SERVICE_MODAL_LOGOUT_CODES=7777,7778

# 后端接口 token 过期状态码（对应 businessCode.tokenExpired=1001）
VITE_SERVICE_EXPIRED_TOKEN_CODES=1001

# 用于区分不同域名下的本地存储
VITE_STORAGE_PREFIX=SOY_

# 用于控制程序是否自动检测更新
VITE_AUTOMATICALLY_DETECT_UPDATE=Y
