{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "lib": ["ESNext"],
    "jsx": "preserve",
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "paths": {
      "#src/*": ["./src/*"],
      "#config/*": ["./src/config/*"],
      "#controllers/*": ["./src/controllers/*"],
      "#jobs/*": ["./src/jobs/*"],
      "#middleware/*": ["./src/middleware/*"],
      "#models/*": ["./src/models/*"],
      "#routers/*": ["./src/routers/*"],
      "#schemas/*": ["./src/schemas/*"],
      "#utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
