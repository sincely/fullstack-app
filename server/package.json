{
  "name": "koa2-app-template",
  "version": "1.0.5",
  "description": "Koa2快速启动基础框架",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/app.js",
    "dev:win": "chcp 65001>nul & cross-env NODE_ENV=development nodemon src/app.js",
    "worker": "cross-env NODE_ENV=development node src/worker.js",
    "worker:dev": "cross-env NODE_ENV=development nodemon src/worker.js",
    "build": "node scripts/build.js",
    "build:test": "npm run build --mode test",
    "build:prod": "npm run build --mode production",
    "deploy:test": "npm run build:test && pm2 reload ecosystem.config.cjs --only koa-app-test",
    "deploy:prod": "npm run build:prod && pm2 reload ecosystem.config.cjs --only koa-app-prod",
    "prod:stop": "pm2 stop koa2-app-template",
    "prod:restart": "pm2 restart koa2-app-template",
    "prod:reload": "pm2 reload koa2-app-template",
    "prod:logs": "pm2 logs koa2-app-template",
    "prod:status": "pm2 status",
    "manual:release": "node scripts/release.js",
    "release": "release-it",
    "release:dry-run": "release-it --dry-run",
    "release:changelog": "release-it --only-changelog",
    "release:github": "release-it --ci --github.release",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:alpha": "release-it --preRelease=alpha",
    "release:beta": "release-it --preRelease=beta",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier:fix": "prettier --write .",
    "lint-staged": "lint-staged",
    "prepare": "node scripts/prepare.js"
  },
  "dependencies": {
    "@koa/bodyparser": "6.1.0",
    "@koa/router": "15.4.0",
    "axios": "1.8.4",
    "bcrypt": "6.0.0",
    "bull": "4.16.5",
    "dotenv": "17.2.4",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "9.0.3",
    "koa": "3.2.0",
    "koa-compress": "5.1.1",
    "koa-session": "6.4.0",
    "koa-static": "5.0.0",
    "koa2-cors": "2.0.6",
    "koa2-swagger-ui": "^5.11.0",
    "mysql2": "3.16.3",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "swagger-jsdoc": "6.2.8",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "17.8.1",
    "@commitlint/config-conventional": "17.8.1",
    "@eslint/js": "9.39.4",
    "@release-it/conventional-changelog": "10.0.4",
    "conventional-changelog-angular": "8.1.0",
    "conventional-changelog-conventionalcommits": "9.1.0",
    "cross-env": "7.0.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "15.1.0",
    "inquirer": "13.2.2",
    "lint-staged": "13.2.3",
    "nodemon": "3.1.11",
    "prettier": "3.8.1",
    "pug": "2.0.4",
    "release-it": "19.2.4"
  }
}
