              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "testuser",
                    "description": "登录用户名"
                  },
                  "password": {
                    "type": "string",
                    "example": "Test123456",
                    "description": "登录密码"
