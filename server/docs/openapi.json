    "/api/admin/auth/register": {
      "post": {
        "tags": ["后台认证"],
        "summary": "后台注册",
        "description": "注册后台账号并绑定默认角色，不包含验证码校验",
        "operationId": "post__admin_auth_register",
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": "业务状态码"
                    },
                    "msg": {
                      "type": "string",
                      "description": "响应消息"
                    },
                    "data": {
                      "type": "object",
                      "description": "响应数据"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password", "confirmPassword", "email"],
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "testuser",
                    "description": "登录用户名"
                  },
                  "password": {
                    "type": "string",
                    "example": "Test123456",
                    "description": "登录密码"
                  },
                  "confirmPassword": {
                    "type": "string",
                    "example": "Test123456",
                    "description": "确认密码"
                  },
                  "email": {
                    "type": "string",
                    "example": "test@example.com",
                    "description": "邮箱地址"
                  }
                }
              },
              "example": {
                "username": "testuser",
                "password": "Test123456",
                "confirmPassword": "Test123456",
                "email": "test@example.com"
              }
            }
          }
        }
      }
    },
    "/api/admin/auth/login": {
      "post": {
        "tags": ["后台认证"],
        "summary": "后台登录",
        "description": "使用用户名和密码登录后台，返回 token、用户信息、菜单和权限数据",
