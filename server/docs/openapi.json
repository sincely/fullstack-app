        "summary": "创建用户",
        "description": "新增后台用户并绑定角色",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password", "email", "roleId"],
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "用户名",
                    "example": "testuser"
                  },
                  "password": {
                    "type": "string",
                    "description": "登录密码",
                    "example": "Test123456"
                  },
                  "gender": {
                    "type": "string",
                    "description": "性别",
                    "example": ""
                  },
                  "age": {
                    "type": "integer",
                    "description": "年龄",
                    "example": 0
                  },
