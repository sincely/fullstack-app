  "paths": {
    "/api/admin/auth/register": {
      "post": {
        "tags": ["后台认证"],
        "summary": "后台注册",
        "description": "注册后台账号并绑定默认角色",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password", "confirmPassword", "email"],
                "properties": {
                  "username": {
                    "type": "string",
                    "description": "登录用户名",
                    "example": "testuser"
                  },
                  "password": {
                    "type": "string",
                    "description": "登录密码",
                    "example": "Test123456"
                  },
                  "confirmPassword": {
                    "type": "string",
                    "description": "确认密码",
                    "example": "Test123456"
                  },
                  "email": {
                    "type": "string",
                    "description": "邮箱地址",
                    "example": "test@example.com"
                  }
                }
              },
              "example": {
                "username": "testuser",
                "password": "Test123456",
                "confirmPassword": "Test123456",
                "email": "test@example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "后台注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "description": "业务状态码"
                    },
                    "msg": {
                      "type": "string",
                      "description": "响应消息"
                    },
                    "data": {
                      "type": "object",
                      "description": "响应数据"
                    }
                  }
                }
              }
            }
          }
        },
        "operationId": "post_admin_auth_register"
      }
    },
